        {
            "caption": "farfield plot options",
            "version": "2025.0|34.0.1|20240830",
            "hidden": false,
            "type": "vba",
            "code": [
                "With FarfieldPlot ",
                "     .Plottype \"3D\" ",
                "     .Vary \"angle1\" ",
                "     .Theta \"0\" ",
